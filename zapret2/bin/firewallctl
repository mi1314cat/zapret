#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - firewallctl（最终修复版）
# 自动检测 nft / iptables / iptables-legacy
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
CFG="$BASE/config"
LIB="$BASE/lib"

source "$LIB/utils.sh"

NFT_MOD="$LIB/firewall_nft.sh"
IPT_MOD="$LIB/firewall_iptables.sh"

detect_backend() {
    # 如果系统已经切换到 iptables-legacy，则优先使用它
    if iptables --version 2>&1 | grep -q "legacy"; then
        echo iptables-legacy
        return
    fi

    # 如果 nft 可用且支持原子加载，则使用 nft
    echo "table inet test { chain c { type filter hook input priority 0; } }" > /tmp/test.nft
    if nft -f /tmp/test.nft >/dev/null 2>&1; then
        echo nft
        return
    fi

    # 否则 fallback 到 iptables
    echo iptables
}

apply_rules() {
    local mode
    mode=$(cat "$CFG/mode.conf" 2>/dev/null || echo local)

    local backend
    backend=$(detect_backend)

    log_info "使用防火墙后端：$backend（mode=$mode）"

    case "$backend" in
        nft)
            source "$NFT_MOD"
            apply_nft_rules "$mode"
            ;;
        iptables|iptables-legacy)
            source "$IPT_MOD"
            apply_iptables_rules "$mode"
            ;;
    esac
}

clear_rules() {
    local backend
    backend=$(detect_backend)

    log_info "清理防火墙规则（后端：$backend）"

    case "$backend" in
        nft)
            source "$NFT_MOD"
            clear_nft_rules
            ;;
        iptables|iptables-legacy)
            source "$IPT_MOD"
            clear_iptables_rules
            ;;
    esac
}

case "${1:-}" in
    apply) apply_rules ;;
    clear) clear_rules ;;
    backend) detect_backend ;;
    *)
        echo "用法：firewallctl {apply|clear|backend}"
        exit 1
        ;;
esac
