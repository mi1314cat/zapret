#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - firewallctl（最终优化版）
# 支持：白名单 / 黑名单 / 默认规则
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
CFG="$BASE/config"
LIB="$BASE/lib"

source "$LIB/utils.sh"

BACKEND="nft"
TABLE="zapret2"
CHAIN="zapret2_chain"
QUEUE_NUM=100

WHITELIST="$CFG/whitelist.txt"
BLACKLIST="$CFG/blacklist.txt"

# ============================================================
# 读取模式
# ============================================================
get_mode() {
    if [[ -f "$CFG/mode.conf" ]]; then
        cat "$CFG/mode.conf"
    else
        echo "local"
    fi
}

# ============================================================
# 清理 nft 表
# ============================================================
nft_clear() {
    nft delete table inet "$TABLE" 2>/dev/null || true
}

# ============================================================
# 加载白名单
# ============================================================
apply_whitelist() {
    [[ ! -f "$WHITELIST" ]] && return 0

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^# ]] && continue

        echo "[FW] 白名单：跳过 $line"
        nft add rule inet "$TABLE" "$CHAIN" ip daddr "$line" counter accept
        nft add rule inet "$TABLE" "$CHAIN" ip saddr "$line" counter accept
    done < "$WHITELIST"
}

# ============================================================
# 加载黑名单
# ============================================================
apply_blacklist() {
    [[ ! -f "$BLACKLIST" ]] && return 0

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^# ]] && continue

        echo "[FW] 黑名单：强制处理 $line"
        nft add rule inet "$TABLE" "$CHAIN" ip daddr "$line" counter queue num "$QUEUE_NUM"
        nft add rule inet "$TABLE" "$CHAIN" ip saddr "$line" counter queue num "$QUEUE_NUM"
    done < "$BLACKLIST"
}

# ============================================================
# 默认规则
# ============================================================
apply_default_rules() {
    local mode
    mode="$(get_mode)"

    echo "[FW] 默认规则（mode=$mode）"

    case "$mode" in
        local)
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$QUEUE_NUM"
            ;;
        gateway)
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$QUEUE_NUM"
            ;;
        *)
            echo "[FW] 未知模式：$mode，按 local 处理"
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$QUEUE_NUM"
            ;;
    esac
}

# ============================================================
# 排除 zapret2 自身流量（防自杀）
# ============================================================
apply_self_protection() {
    echo "[FW] 排除 zapret2 自身流量"

    # 排除 zapret2d / nfqws2 自身
    nft add rule inet "$TABLE" "$CHAIN" meta skuid 0 counter accept
    nft add rule inet "$TABLE" "$CHAIN" meta skgid 0 counter accept

    # 排除本机回环
    nft add rule inet "$TABLE" "$CHAIN" ip saddr 127.0.0.1 counter accept
    nft add rule inet "$TABLE" "$CHAIN" ip daddr 127.0.0.1 counter accept
}

# ============================================================
# 加载 nft 规则
# ============================================================
nft_apply() {
    nft_clear

    nft add table inet "$TABLE"
    nft add chain inet "$TABLE" "$CHAIN" '{ type filter hook prerouting priority 0; policy accept; }'

    apply_self_protection
    apply_whitelist
    apply_blacklist
    apply_default_rules

    echo "[FW] nftables 规则加载完成"
}

# ============================================================
# 状态
# ============================================================
nft_status() {
    if nft list table inet "$TABLE" >/dev/null 2>&1; then
        nft list table inet "$TABLE"
    else
        echo "[FW] 表不存在：$TABLE"
    fi
}

# ============================================================
# 主入口
# ============================================================
case "${1:-}" in
    apply)
        echo "[FW] 使用 nft 后端（mode=$(get_mode)）"
        nft_apply
        ;;
    clear)
        echo "[FW] 清理 nft 规则..."
        nft_clear
        ;;
    status)
        nft_status
        ;;
    *)
        echo "用法: $0 {apply|clear|status}"
        exit 1
        ;;
esac
