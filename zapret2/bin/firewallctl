#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - firewallctl（终极版）
# IPv4/IPv6 / qnum/qsize / hostlist/iplist / whitelist/blacklist
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
CFG="$BASE/config"
LIB="$BASE/lib"

source "$LIB/utils.sh"

TABLE="zapret2"
CHAIN="zapret2_chain"

WHITELIST="$CFG/whitelist.txt"
BLACKLIST="$CFG/blacklist.txt"
HOSTLIST="$CFG/hostlist.txt"
IPLIST="$CFG/iplist.txt"
QCONF="$CFG/qnum.conf"

# ============================================================
# 读取配置
# ============================================================
get_mode() {
    [[ -f "$CFG/mode.conf" ]] && cat "$CFG/mode.conf" || echo "local"
}

get_qnum() {
    grep -E '^qnum=' "$QCONF" 2>/dev/null | cut -d= -f2 || echo "100"
}

get_qsize() {
    grep -E '^qsize=' "$QCONF" 2>/dev/null | cut -d= -f2 || echo "4096"
}

# ============================================================
# 清理 nft 表
# ============================================================
nft_clear() {
    nft delete table inet "$TABLE" 2>/dev/null || true
}

# ============================================================
# 自身保护（防自杀）
# ============================================================
apply_self_protection() {
    log_info "[FW] 自身保护规则加载中..."

    # 回环
    nft add rule inet "$TABLE" "$CHAIN" ip saddr 127.0.0.1 counter accept
    nft add rule inet "$TABLE" "$CHAIN" ip daddr 127.0.0.1 counter accept
    nft add rule inet "$TABLE" "$CHAIN" ip6 saddr ::1 counter accept
    nft add rule inet "$TABLE" "$CHAIN" ip6 daddr ::1 counter accept

    # 本机所有 IPv4
    ip -4 addr show scope global | awk '/inet /{print $2}' | while read -r cidr; do
        ip="${cidr%/*}"
        nft add rule inet "$TABLE" "$CHAIN" ip saddr "$ip" counter accept
        nft add rule inet "$TABLE" "$CHAIN" ip daddr "$ip" counter accept
    done

    # 本机所有 IPv6
    ip -6 addr show scope global | awk '/inet6 /{print $2}' | while read -r cidr; do
        ip="${cidr%/*}"
        nft add rule inet "$TABLE" "$CHAIN" ip6 saddr "$ip" counter accept
        nft add rule inet "$TABLE" "$CHAIN" ip6 daddr "$ip" counter accept
    done

    ok "[FW] 自身保护规则已加载"
}

# ============================================================
# 白名单
# ============================================================
apply_whitelist() {
    [[ ! -f "$WHITELIST" ]] && return

    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        log_info "[FW] 白名单：$line"

        if [[ "$line" == *:* ]]; then
            nft add rule inet "$TABLE" "$CHAIN" ip6 daddr "$line" counter accept
            nft add rule inet "$TABLE" "$CHAIN" ip6 saddr "$line" counter accept
        else
            nft add rule inet "$TABLE" "$CHAIN" ip daddr "$line" counter accept
            nft add rule inet "$TABLE" "$CHAIN" ip saddr "$line" counter accept
        fi
    done < "$WHITELIST"
}

# ============================================================
# 黑名单
# ============================================================
apply_blacklist() {
    [[ ! -f "$BLACKLIST" ]] && return

    local qnum
    qnum="$(get_qnum)"

    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        log_info "[FW] 黑名单：$line"

        if [[ "$line" == *:* ]]; then
            nft add rule inet "$TABLE" "$CHAIN" ip6 daddr "$line" counter queue num "$qnum"
            nft add rule inet "$TABLE" "$CHAIN" ip6 saddr "$line" counter queue num "$qnum"
        else
            nft add rule inet "$TABLE" "$CHAIN" ip daddr "$line" counter queue num "$qnum"
            nft add rule inet "$TABLE" "$CHAIN" ip saddr "$line" counter queue num "$qnum"
        fi
    done < "$BLACKLIST"
}

# ============================================================
# hostlist（域名 → set）
# ============================================================
apply_hostlist() {
    [[ ! -f "$HOSTLIST" ]] && return

    log_info "[FW] 加载 hostlist（域名）"

    nft add set inet "$TABLE" hostlist '{ type string; flags interval; }' 2>/dev/null || true

    while IFS= read -r host; do
        [[ -z "$host" || "$host" =~ ^# ]] && continue
        nft add element inet "$TABLE" hostlist { "\"$host\"" } 2>/dev/null || true
    done < "$HOSTLIST"
}

# ============================================================
# iplist（IP → set）
# ============================================================
apply_iplist() {
    [[ ! -f "$IPLIST" ]] && return

    log_info "[FW] 加载 iplist（IP）"

    nft add set inet "$TABLE" iplist '{ type ipv4_addr; flags interval; }' 2>/dev/null || true

    while IFS= read -r ip; do
        [[ -z "$ip" || "$ip" =~ ^# ]] && continue
        nft add element inet "$TABLE" iplist { "$ip" } 2>/dev/null || true
    done < "$IPLIST"
}

# ============================================================
# 默认规则（local / gateway）
# ============================================================
apply_default_rules() {
    local mode qnum qsize
    mode="$(get_mode)"
    qnum="$(get_qnum)"
    qsize="$(get_qsize)"

    log_info "[FW] 默认规则（mode=$mode, qnum=$qnum, qsize=$qsize）"

    # 设置 NFQUEUE 队列大小
    sysctl -w net.netfilter.nf_queue_maxlen="$qsize" >/dev/null 2>&1 || true

    case "$mode" in
        local)
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$qnum"
            ;;
        gateway)
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$qnum"
            ;;
        *)
            log_warn "[FW] 未知模式：$mode，按 local 处理"
            nft add rule inet "$TABLE" "$CHAIN" meta l4proto tcp counter queue num "$qnum"
            ;;
    esac
}

# ============================================================
# 加载 nft 规则
# ============================================================
nft_apply() {
    log_info "[FW] 使用 nft 后端（mode=$(get_mode)）"

    nft_clear

    nft add table inet "$TABLE"
    nft add chain inet "$TABLE" "$CHAIN" '{ type filter hook prerouting priority 0; policy accept; }'

    apply_self_protection
    apply_whitelist
    apply_blacklist
    apply_hostlist
    apply_iplist
    apply_default_rules

    ok "[FW] nftables 规则加载完成"
}

# ============================================================
# 状态
# ============================================================
nft_status() {
    if nft list table inet "$TABLE" >/dev/null 2>&1; then
        nft list table inet "$TABLE"
    else
        log_warn "[FW] 表不存在：$TABLE"
    fi
}

# ============================================================
# 主入口
# ============================================================
case "${1:-}" in
    apply)
        nft_apply
        ;;
    clear)
        log_info "[FW] 清理 nft 规则..."
        nft_clear
        ;;
    status)
        nft_status
        ;;
    *)
        echo "用法: $0 {apply|clear|status}"
        exit 1
        ;;
esac
