#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - zapret2d（单实例 + 自愈）
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
BIN="$BASE/bin"
LIB="$BASE/lib"
CFG="$BASE/config"

LOG_DIR="/var/log/zapret2"
LOG_FILE="$LOG_DIR/zapret2d.log"
PID_FILE="/run/zapret2d.pid"
LOCK_FILE="/run/zapret2d.lock"

mkdir -p "$LOG_DIR"

source "$LIB/utils.sh"
source "$LIB/zapret2_core.sh"

FIREWALLCTL="$BIN/firewallctl"
HEALTHCHECK="$BIN/healthcheck"

# ============================================================
# 单实例锁（PID + flock）
# ============================================================
acquire_lock() {
    exec 9>"$LOCK_FILE"

    if ! flock -n 9; then
        echo "[FATAL] 另一个 zapret2d 实例正在运行（flock 锁）"
        exit 1
    fi

    if [[ -f "$PID_FILE" ]]; then
        old_pid=$(cat "$PID_FILE" || true)
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            echo "[FATAL] 另一个 zapret2d 实例正在运行（PID 锁）"
            exit 1
        fi
    fi

    echo $$ > "$PID_FILE"
}

cleanup() {
    rm -f "$PID_FILE"
    killall -9 nfqws2 2>/dev/null || true
    "$FIREWALLCTL" clear || true
}
trap cleanup EXIT

# ============================================================
# 防火墙加载
# ============================================================
load_firewall() {
    echo "[INFO] 加载防火墙规则..."
    "$FIREWALLCTL" apply
}

# ============================================================
# 健康检查循环：只管 nfqws2，不动 zapret2d
# ============================================================
health_loop() {
    while true; do
        sleep 5

        if ! "$HEALTHCHECK" >/dev/null 2>&1; then
            echo "[WARN] 健康检查失败，正在重启 nfqws2..."
            killall -9 nfqws2 2>/dev/null || true
            sleep 1
            # 这里假设 zapret2_core_main 只负责 nfqws2，不再做锁之类的事
            zapret2_core_main &
        fi
    done
}

# ============================================================
# 主入口
# ============================================================
main() {
    require_root
    acquire_lock

    exec > >(tee -a "$LOG_FILE") 2>&1

    echo "========== $(date) - zapret2d 启动 =========="

    load_firewall

    # 启动 nfqws2
    zapret2_core_main &

    # 健康循环
    health_loop
}

main
