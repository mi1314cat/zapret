#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - zapret2d（单实例 + 自愈）
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
BIN="$BASE/bin"
LIB="$BASE/lib"
CFG="$BASE/config"

LOG_DIR="/var/log/zapret2"
LOG_FILE="$LOG_DIR/zapret2d.log"
PID_FILE="/run/zapret2d.pid"
LOCK_FILE="/run/zapret2d.lock"

mkdir -p "$LOG_DIR"

source "$LIB/utils.sh"
source "$BASE/zapret2_core.sh"

FIREWALLCTL="$BIN/firewallctl"
HEALTHCHECK="$BIN/healthcheck"

require_root

# ============================================================
# 单实例锁（PID + flock）
# ============================================================
acquire_lock() {
    exec 9>"$LOCK_FILE"

    if ! flock -n 9; then
        err "另一个 zapret2d 实例正在运行（flock 锁）"
        exit 1
    fi

    if [[ -f "$PID_FILE" ]]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" || true)
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            err "另一个 zapret2d 实例正在运行（PID 锁）"
            exit 1
        fi
    fi

    echo $$ > "$PID_FILE"
}

cleanup() {
    warn "清理 zapret2d 运行环境..."
    rm -f "$PID_FILE"
    killall -9 nfqws2 2>/dev/null || true
    "$FIREWALLCTL" clear || true
}
trap cleanup EXIT

# ============================================================
# 防火墙加载
# ============================================================
load_firewall() {
    info "[FW] 加载防火墙规则..."
    "$FIREWALLCTL" apply
}

# ============================================================
# 健康检查循环：只管 nfqws2，不动 zapret2d
# ============================================================
health_loop() {
    while true; do
        sleep 5

        if ! "$HEALTHCHECK" >/dev/null 2>&1; then
            warn "[HEALTH] 健康检查失败，正在重启 nfqws2..."
            killall -9 nfqws2 2>/dev/null || true
            sleep 1
            zapret2_core_main || err "重启 nfqws2 失败"
        fi
    done
}

main() {
    acquire_lock

    ok "Zapret2 v7.0 守护进程启动"
    load_firewall

    info "[CORE] 启动 nfqws2..."
    zapret2_core_main

    info "[HEALTH] 启动健康检查循环..."
    health_loop
}

main "$@" 2>&1 | tee -a "$LOG_FILE"
