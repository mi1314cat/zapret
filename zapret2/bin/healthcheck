#!/usr/bin/env bash
# ============================================================
# Zapret2 v7.0 - healthcheck（最终优化版）
# 只检查 nfqws2，不检查 zapret2d，不触发锁
# ============================================================

set -euo pipefail

BASE="/root/catmi/Zapret2"
LIB="$BASE/lib"

source "$LIB/utils.sh"

NFQWS_BIN="$BASE/bin/nfqws2"
QUEUE_NUM=100

# ============================================================
# 1. 检查 nfqws2 是否存活
# ============================================================
check_process() {
    if ! pgrep -x nfqws2 >/dev/null 2>&1; then
        echo "[HC] nfqws2 未运行"
        return 1
    fi
    return 0
}

# ============================================================
# 2. 检查 NFQUEUE 是否正常绑定
# ============================================================
check_nfqueue() {
    # nfqws2 必须绑定 NFQUEUE
    if ! ss -u -a | grep -q "nfqueue"; then
        echo "[HC] NFQUEUE 未绑定"
        return 1
    fi
    return 0
}

# ============================================================
# 3. 检查 CPU 是否卡死（长时间 0%）
# ============================================================
check_cpu() {
    local pid cpu
    pid=$(pgrep -x nfqws2 || true)

    [[ -z "$pid" ]] && return 1

    cpu=$(ps -p "$pid" -o %cpu= | awk '{print int($1)}')

    if (( cpu == 0 )); then
        echo "[HC] nfqws2 CPU 为 0%，可能卡死"
        return 1
    fi

    return 0
}

# ============================================================
# 4. 检查内存泄漏（>200MB）
# ============================================================
check_memory() {
    local pid mem
    pid=$(pgrep -x nfqws2 || true)

    [[ -z "$pid" ]] && return 1

    mem=$(ps -p "$pid" -o rss= | awk '{print int($1)}')

    if (( mem > 200000 )); then
        echo "[HC] nfqws2 内存异常：${mem}KB"
        return 1
    fi

    return 0
}

# ============================================================
# 综合健康检查
# ============================================================
run_healthcheck() {
    local status=0

    check_process   || status=1
    check_nfqueue   || status=1
    check_cpu       || status=1
    check_memory    || status=1

    if (( status == 0 )); then
        echo "[HC] OK"
    else
        echo "[HC] FAIL"
    fi

    return "$status"
}

run_healthcheck
